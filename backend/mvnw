#!/bin/sh
set -e

if [ -z "$MAVEN_BASEDIR" ]; then
  MAVEN_BASEDIR=$(cd "$(dirname "$0")" && pwd)
fi

MAVEN_WRAPPER_PROPERTIES="$MAVEN_BASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
  DIST_URL=$(grep -E '^distributionUrl=' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

if [ -z "$DIST_URL" ]; then
  DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"
fi

MAVEN_HOME="$HOME/.m2/wrapper/dists/$(basename "$DIST_URL" .zip)"

if [ ! -f "$MAVEN_HOME/bin/mvn" ]; then
  echo "Downloading Maven from $DIST_URL..."
  mkdir -p "$MAVEN_HOME"
  TMPFILE=$(mktemp /tmp/maven-dist.XXXXXX.zip)
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$TMPFILE" "$DIST_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMPFILE" "$DIST_URL"
  else
    echo "Error: curl or wget required" >&2
    exit 1
  fi
  EXTRACT_DIR=$(mktemp -d /tmp/maven-extract.XXXXXX)
  unzip -q "$TMPFILE" -d "$EXTRACT_DIR"
  mv "$EXTRACT_DIR"/apache-maven-*/* "$MAVEN_HOME/"
  rm -rf "$TMPFILE" "$EXTRACT_DIR"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
